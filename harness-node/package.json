    "migrate": "node harness/agentLoop.js --config config/migration.yaml"
  },
  "engines": { "node": ">=20" },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.40.0",
    "yaml": "^2.5.0"
  }
}
