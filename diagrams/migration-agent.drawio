        <!-- Loop edges -->
        <mxCell id="e1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#185FA5;endArrow=block;" edge="1" parent="1" source="think" target="act"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#185FA5;endArrow=block;" edge="1" parent="1" source="act" target="observe"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#185FA5;endArrow=block;" edge="1" parent="1" source="observe" target="check"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e4" value="loop" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#185FA5;endArrow=block;fontColor=#185FA5;fontSize=10;" edge="1" parent="1" source="check" target="think"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Act -> guard -> tools -> observe -->
        <mxCell id="e5" value="tool call" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8f3f26;endArrow=block;fontColor=#8f3f26;fontSize=10;" edge="1" parent="1" source="act" target="guard"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e6" value="if allowed" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#8f3f26;endArrow=block;fontColor=#8f3f26;fontSize=10;" edge="1" parent="1" source="guard" target="tools"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e7" value="results" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#0F6E56;endArrow=block;fontColor=#0F6E56;fontSize=10;exitX=1;exitY=0.2;entryX=0.5;entryY=1;" edge="1" parent="1" source="tools" target="observe"><mxGeometry relative="1" as="geometry" /></mxCell>

