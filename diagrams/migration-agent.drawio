        <mxCell id="e12" value="transforms" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3B6D11;endArrow=block;fontColor=#3B6D11;fontSize=10;" edge="1" parent="1" source="tools" target="tgt"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e13" value="logs every decision" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#13263d;endArrow=block;dashed=1;fontColor=#13263d;fontSize=10;" edge="1" parent="1" source="guard" target="audit"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="e14" value="adds tools" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#854F0B;endArrow=block;dashed=1;fontColor=#854F0B;fontSize=10;" edge="1" parent="1" source="mcp" target="tools"><mxGeometry relative="1" as="geometry" /></mxCell>

        <!-- Config configures everything (dashed) -->
