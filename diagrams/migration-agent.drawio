        </mxCell>
        <mxCell id="t7" value="git_commit  —  human-approval gated" style="rounded=1;fillColor=#FAECE7;strokeColor=#993C1D;fontColor=#712b13;fontSize=11;fontStyle=2;" vertex="1" parent="1">
