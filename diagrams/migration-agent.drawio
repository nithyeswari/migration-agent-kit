        <mxCell id="e9" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#534AB7;endArrow=block;dashed=1;" edge="1" parent="1" source="skillnote" target="think"><mxGeometry relative="1" as="geometry" /></mxCell>

