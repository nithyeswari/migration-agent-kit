        <mxCell id="c2" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1F3A5F;endArrow=open;dashed=1;" edge="1" parent="1" source="cfg" target="harness"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="c3" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#1F3A5F;endArrow=open;dashed=1;" edge="1" parent="1" source="cfg" target="tools"><mxGeometry relative="1" as="geometry" /></mxCell>

