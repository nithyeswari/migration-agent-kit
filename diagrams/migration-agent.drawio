<mxfile host="app.diagrams.net" version="24.0.0">
  <diagram name="Quarkus Migration Agent" id="mig-agent">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1250" pageHeight="870" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <!-- Plugin outer container -->
        <mxCell id="plugin" value="Plugin: quarkus-migration  —  one installable bundle (plugin.json). Ships the skill, agent, MCP tools and guardrail hooks together." style="rounded=1;dashed=1;dashPattern=6 4;fillColor=#F5EFE6;strokeColor=#C7603F;fontColor=#5a3a2c;align=left;verticalAlign=top;spacingLeft=14;spacingTop=10;fontSize=12;fontStyle=2;" vertex="1" parent="1">
          <mxGeometry x="20" y="20" width="1200" height="830" as="geometry" />
        </mxCell>

        <!-- Config layer -->
        <mxCell id="cfg" value="config/migration.yaml  —  the single place every knob lives:  model · loop (max_iterations, stop_when) · which tools are enabled · guardrails · prompts" style="rounded=1;fillColor=#1F3A5F;strokeColor=#13263d;fontColor=#ffffff;fontSize=12;fontStyle=1;align=center;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="1140" height="56" as="geometry" />
        </mxCell>

        <!-- Agent -->
        <mxCell id="agent" value="AGENT&#10;quarkus-migrator&#10;&#10;Persona + bounded tool set&#10;(agents/quarkus-migrator.agent.md&#10;= config: agent.*)" style="rounded=1;fillColor=#2E7D8F;strokeColor=#1f5560;fontColor=#ffffff;fontSize=12;fontStyle=0;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="170" width="240" height="150" as="geometry" />
        </mxCell>

        <!-- Outcome -->
        <mxCell id="outcome" value="Outcome&#10;Migrated module + migration summary&#10;(changed deps, recipe output, manual fixes)" style="rounded=1;fillColor=#eef6f1;strokeColor=#3B6D11;fontColor=#27500a;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="60" y="380" width="240" height="90" as="geometry" />
        </mxCell>

        <!-- Harness container -->
        <mxCell id="harness" value="HARNESS  (harness/agent_loop.py)" style="rounded=1;fillColor=#ffffff;strokeColor=#888780;fontColor=#444441;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="340" y="160" width="480" height="410" as="geometry" />
        </mxCell>

        <!-- Loop nodes -->
        <mxCell id="think" value="1. THINK&#10;ask the model what to do&#10;(llm.py)" style="rounded=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0c447c;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="370" y="205" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="act" value="2. ACT&#10;run the tool calls it returned" style="rounded=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0c447c;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="610" y="205" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="observe" value="3. OBSERVE&#10;feed tool results back to model" style="rounded=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0c447c;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="610" y="305" width="180" height="56" as="geometry" />
        </mxCell>
        <mxCell id="check" value="4. STOP?&#10;tests_green / max_iter / done" style="rounded=1;fillColor=#E6F1FB;strokeColor=#185FA5;fontColor=#0c447c;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="370" y="305" width="180" height="56" as="geometry" />
        </mxCell>

        <!-- Guardrails gate inside harness -->
        <mxCell id="guard" value="GUARDRAILS GATE  (runs before EVERY tool)&#10;allowed_paths · deny list · human approval · redact secrets" style="rounded=1;fillColor=#C7603F;strokeColor=#8f3f26;fontColor=#ffffff;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="430" y="420" width="320" height="56" as="geometry" />
        </mxCell>
        <mxCell id="skillnote" value="Skill: spring-to-quarkus (SKILL.md)&#10;procedure the THINK step loads on demand" style="rounded=1;fillColor=#EEEDFE;strokeColor=#534AB7;fontColor=#3c3489;fontSize=10;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="370" y="495" width="380" height="50" as="geometry" />
        </mxCell>

        <!-- Tools container -->
        <mxCell id="tools" value="TOOLS  (harness/tools.py registry — toggle each one in config: agent.tools)" style="rounded=1;fillColor=#ffffff;strokeColor=#888780;fontColor=#444441;align=left;verticalAlign=top;spacingLeft=12;spacingTop=8;fontSize=12;fontStyle=1;whiteSpace=wrap;" vertex="1" parent="1">
