        <mxCell id="e10" value="stop met" style="edgeStyle=orthogonalEdgeStyle;rounded=1;strokeColor=#3B6D11;endArrow=block;fontColor=#3B6D11;fontSize=10;" edge="1" parent="1" source="check" target="outcome"><mxGeometry relative="1" as="geometry" /></mxCell>

