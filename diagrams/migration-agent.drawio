        <mxCell id="tgt" value="Quarkus 3.x / Java 21&#10;(TARGET)" style="rounded=1;fillColor=#EAF3DE;strokeColor=#3B6D11;fontColor=#27500a;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="880" y="300" width="180" height="64" as="geometry" />
        </mxCell>
        <mxCell id="audit" value="Audit trail&#10;JSONL, OTel-style fields&#10;audit/migration-trace.jsonl" style="rounded=1;fillColor=#1F3A5F;strokeColor=#13263d;fontColor=#ffffff;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="880" y="420" width="180" height="70" as="geometry" />
        </mxCell>
        <mxCell id="mcp" value="MCP servers (.mcp.json)&#10;extra tools, same registry&#10;(OpenRewrite, build-runner)" style="rounded=1;fillColor=#FAEEDA;strokeColor=#854F0B;fontColor=#633806;fontSize=11;align=center;whiteSpace=wrap;" vertex="1" parent="1">
          <mxGeometry x="880" y="600" width="180" height="70" as="geometry" />
