{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "editFiles|runCommands",
        "hooks": [
          { "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/guard-allowed-paths.sh" }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "editFiles",
        "hooks": [
          { "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/audit-log.sh" }
        ]
      }
    ]
  }
}
